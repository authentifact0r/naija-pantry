# Database
DATABASE_URL="postgresql://user:password@localhost:5432/naijapantry?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"

# Paystack (preferred for Nigerian context)
PAYSTACK_SECRET_KEY="sk_test_xxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxx"
PAYSTACK_WEBHOOK_SECRET="whsec_xxxx"

# Stripe (international fallback)
STRIPE_SECRET_KEY="sk_test_xxxx"
STRIPE_PUBLIC_KEY="pk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxx"

# Local delivery hub coordinates (Lagos example)
LOCAL_HUB_LAT="6.5244"
LOCAL_HUB_LNG="3.3792"
LOCAL_DELIVERY_RADIUS_KM="15"
