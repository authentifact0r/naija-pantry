generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT SYSTEM ─────────────────────────────────────────

model Tenant {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  customDomain     String?  @unique
  logo             String?
  favicon          String?
  primaryColor     String   @default("#064E3B")
  accentColor      String   @default("#F59E0B")
  tagline          String?
  paystackSecretKey String?
  paystackPublicKey String?
  stripeSecretKey  String?
  stripePublicKey  String?
  localHubLat      Float?
  localHubLng      Float?
  localRadiusKm    Float    @default(15)
  freeShippingMinimum Float?
  currency         String   @default("NGN")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // SEO defaults
  defaultMetaTitle       String?
  defaultMetaDescription String?
  defaultOgImage         String?

  // Mobile app
  mobileAppEnabled    Boolean  @default(false)
  mobileAppBrandName  String?  // e.g., "Taste of Motherland"
  mobileAppIcon       String?

  // Hero/banner
  heroBannerImage     String?
  heroBannerTitle     String?
  heroBannerSubtitle  String?

  // ── Billing ──
  billingPlan            String   @default("standard") // basic | standard | premium
  billingStatus          String   @default("active")   // active | delinquent | paused
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  nextInvoiceDate        DateTime?
  lastPaymentStatus      String?  // succeeded | failed | pending
  lastPaymentDate        DateTime?
  billingEmail           String?  // override for billing notifications
  hostingProvider        String   @default("vercel") // gcp | vercel | hybrid

  // Last invoice breakdown (updated by webhook)
  lastInvoiceTotalGbp       Float?
  lastInvoiceBaseRetainerGbp Float?
  lastInvoiceHostingUsageGbp Float?
  lastInvoiceBackendUsageGbp Float?

  // Stripe metered subscription items
  stripeHostingItemId    String?  // subscription_item for hosting usage
  stripeBackendItemId    String?  // subscription_item for backend usage

  // Vercel project mapping
  vercelProjectId        String?

  tenantUsers      TenantUser[]
  usageRecords     TenantUsage[]
  products         Product[]
  warehouses       Warehouse[]
  inventoryBatches InventoryBatch[]
  cartItems        CartItem[]
  orders           Order[]
  subscriptions    Subscription[]
  recipes          Recipe[]
  flashSales       FlashSale[]
  shippingRules    ShippingRule[]
  seoSettings      SeoSettings[]
  onboardingProgress OnboardingProgress?

  @@map("tenants")
}

// ─── USER SYSTEM ─────────────────────────────────────────────

enum TenantRole {
  CUSTOMER
  MANAGER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  tenantUsers   TenantUser[]

  @@map("users")
}

model TenantUser {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      TenantRole @default(CUSTOMER)
  createdAt DateTime   @default(now())

  @@unique([userId, tenantId])
  @@map("tenant_users")
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String  @default("Home") // Home, Office, etc.
  firstName   String
  lastName    String
  line1       String
  line2       String?
  city        String
  state       String
  postcode    String
  country     String  @default("NG")
  phone       String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  orders      Order[]

  @@map("addresses")
}

// ─── PRODUCT & CATALOG ──────────────────────────────────────

enum ProductCategory {
  GROCERIES
  SPICES
  DRINKS
  BEAUTY
}

model Product {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String
  name            String
  slug            String
  description     String
  category        ProductCategory
  price           Decimal         @db.Decimal(10, 2)
  compareAtPrice  Decimal?        @db.Decimal(10, 2) // original price for sales
  weightKg        Decimal         @db.Decimal(6, 3)  // critical for shipping
  isPerishable    Boolean         @default(false)
  isFragile       Boolean         @default(false)
  isSubscribable  Boolean         @default(false)    // eligible for auto-ship
  tags            String[]        // e.g., ["staple", "nigerian", "vegan"]
  images          String[]        // URLs
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  inventoryBatches InventoryBatch[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  recipeItems      RecipeItem[]
  subscriptions    Subscription[]
  flashSale        FlashSale?

  @@unique([tenantId, sku])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([category])
  @@map("products")
}

// ─── MULTI-WAREHOUSE INVENTORY WITH BATCH TRACKING ──────────

model Warehouse {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String
  city      String
  state     String
  country   String  @default("NG")
  latitude  Float
  longitude Float
  isActive  Boolean @default(true)

  inventoryBatches InventoryBatch[]
  orders           Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model InventoryBatch {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNumber String?
  quantity    Int
  expiryDate  DateTime?
  costPrice   Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([productId, warehouseId])
  @@index([expiryDate])
  @@map("inventory_batches")
}

// ─── CART ────────────────────────────────────────────────────

model CartItem {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, tenantId])
  @@index([tenantId])
  @@map("cart_items")
}

// ─── ORDERS ─────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShippingMethod {
  LOCAL_FRESH    // Same-day local delivery for perishables
  STANDARD       // National dry goods shipping
  EXPRESS        // Priority shipping
  LOCAL_VAN      // Local van delivery for heavy items
  DHL            // International/premium
}

model Order {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber     String         @unique
  userId          String
  addressId       String
  address         Address        @relation(fields: [addressId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])

  status          OrderStatus    @default(PENDING)
  subtotal        Decimal        @db.Decimal(10, 2)
  shippingCost    Decimal        @db.Decimal(10, 2)
  tax             Decimal        @db.Decimal(10, 2) @default(0)
  discount        Decimal        @db.Decimal(10, 2) @default(0)
  total           Decimal        @db.Decimal(10, 2)
  totalWeightKg   Decimal        @db.Decimal(8, 3)

  shippingMethod  ShippingMethod
  paymentProvider PaymentProvider
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentRef      String?        // Paystack/Stripe reference
  trackingNumber  String?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  shippedAt       DateTime?
  deliveredAt     DateTime?

  items           OrderItem[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  weightKg    Decimal @db.Decimal(6, 3)

  @@map("order_items")
}

// ─── SUBSCRIPTIONS (AUTO-SHIP) ──────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SubscriptionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Subscription {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  productId       String
  product         Product            @relation(fields: [productId], references: [id])
  quantity        Int                @default(1)
  interval        SubscriptionInterval @default(MONTHLY)
  status          SubscriptionStatus @default(ACTIVE)
  discountPercent Decimal            @db.Decimal(4, 2) @default(5.00)
  nextDelivery    DateTime
  paymentRef      String?            // recurring billing ref
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([nextDelivery])
  @@map("subscriptions")
}

// ─── RECIPES ────────────────────────────────────────────────

model Recipe {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String
  image       String?
  prepTime    Int          // minutes
  cookTime    Int          // minutes
  servings    Int
  instructions String     // markdown or HTML
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items       RecipeItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("recipes")
}

model RecipeItem {
  id          String  @id @default(cuid())
  recipeId    String
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int     @default(1)
  measurement String? // e.g., "2 cups", "1 tablespoon"

  @@map("recipe_items")
}

// ─── FLASH SALES ────────────────────────────────────────────

model FlashSale {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPercent Decimal  @db.Decimal(4, 2)
  reason          String?  // e.g., "Near expiry"
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([isActive, endsAt])
  @@map("flash_sales")
}

// ─── SHIPPING RULES ────────────────────────────────────────

model ShippingRule {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  method        ShippingMethod
  minWeightKg   Decimal       @db.Decimal(8, 3)
  maxWeightKg   Decimal       @db.Decimal(8, 3)
  baseCost      Decimal       @db.Decimal(10, 2)
  perKgCost     Decimal       @db.Decimal(10, 2)
  estimatedDays Int
  isActive      Boolean       @default(true)

  @@index([tenantId])
  @@map("shipping_rules")
}

// ─── SEO SETTINGS ──────────────────────────────────────────

model SeoSettings {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageType        String   // "home", "category", "product", "recipe", "custom"
  pageSlug        String?  // null for home, category slug, product slug, etc.
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  jsonLd          String?  // JSON-LD structured data as string
  canonicalUrl    String?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, pageType, pageSlug])
  @@index([tenantId])
  @@map("seo_settings")
}

// ─── ONBOARDING ────────────────────────────────────────────

model OnboardingProgress {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branding    Boolean  @default(false)
  domain      Boolean  @default(false)
  warehouse   Boolean  @default(false)
  inventory   Boolean  @default(false)
  shipping    Boolean  @default(false)
  seo         Boolean  @default(false)
  adminUsers  Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  @@map("onboarding_progress")
}

// ─── USAGE BILLING ─────────────────────────────────────────

model TenantUsage {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime
  reportedAt  DateTime @default(now())

  // GCP usage
  gcpCloudRunRequests     Int      @default(0)
  gcpCloudRunCpuSeconds   Float    @default(0)
  gcpCloudRunMemoryGbHrs  Float    @default(0)
  gcpFirestoreReads       Int      @default(0)
  gcpFirestoreWrites      Int      @default(0)
  gcpFirestoreStorageGb   Float    @default(0)
  gcpStorageGb            Float    @default(0)
  gcpStorageEgressGb      Float    @default(0)

  // Vercel usage
  vercelBuildMinutes          Float  @default(0)
  vercelServerlessInvocations Int    @default(0)
  vercelBandwidthGb           Float  @default(0)
  vercelImageOptimizations    Int    @default(0)
  vercelEdgeRequests          Int    @default(0)

  // Computed cost
  gcpCostGbp     Float  @default(0)
  vercelCostGbp  Float  @default(0)
  totalCostGbp   Float  @default(0)

  // Stripe metered billing
  stripeReported Boolean @default(false) // whether usage was sent to Stripe

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@map("tenant_usage")
}
