generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER SYSTEM ─────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  MANAGER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  cartItems     CartItem[]
  subscriptions Subscription[]

  @@map("users")
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String  @default("Home") // Home, Office, etc.
  firstName   String
  lastName    String
  line1       String
  line2       String?
  city        String
  state       String
  postcode    String
  country     String  @default("NG")
  phone       String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  orders      Order[]

  @@map("addresses")
}

// ─── PRODUCT & CATALOG ──────────────────────────────────────

enum ProductCategory {
  GROCERIES
  SPICES
  DRINKS
  BEAUTY
}

model Product {
  id              String          @id @default(cuid())
  sku             String          @unique
  name            String
  slug            String          @unique
  description     String
  category        ProductCategory
  price           Decimal         @db.Decimal(10, 2)
  compareAtPrice  Decimal?        @db.Decimal(10, 2) // original price for sales
  weightKg        Decimal         @db.Decimal(6, 3)  // critical for shipping
  isPerishable    Boolean         @default(false)
  isFragile       Boolean         @default(false)
  isSubscribable  Boolean         @default(false)    // eligible for auto-ship
  tags            String[]        // e.g., ["staple", "nigerian", "vegan"]
  images          String[]        // URLs
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  inventoryBatches InventoryBatch[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  recipeItems      RecipeItem[]
  subscriptions    Subscription[]
  flashSale        FlashSale?

  @@index([category])
  @@index([slug])
  @@map("products")
}

// ─── MULTI-WAREHOUSE INVENTORY WITH BATCH TRACKING ──────────

model Warehouse {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique // e.g., "LOS", "ABJ", "LON"
  address   String
  city      String
  state     String
  country   String  @default("NG")
  latitude  Float
  longitude Float
  isActive  Boolean @default(true)

  inventoryBatches InventoryBatch[]
  orders           Order[]

  @@map("warehouses")
}

model InventoryBatch {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNumber String?
  quantity    Int
  expiryDate  DateTime?
  costPrice   Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId, warehouseId])
  @@index([expiryDate])
  @@map("inventory_batches")
}

// ─── CART ────────────────────────────────────────────────────

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

// ─── ORDERS ─────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShippingMethod {
  LOCAL_FRESH    // Same-day local delivery for perishables
  STANDARD       // National dry goods shipping
  EXPRESS        // Priority shipping
  LOCAL_VAN      // Local van delivery for heavy items
  DHL            // International/premium
}

model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  addressId       String
  address         Address        @relation(fields: [addressId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])

  status          OrderStatus    @default(PENDING)
  subtotal        Decimal        @db.Decimal(10, 2)
  shippingCost    Decimal        @db.Decimal(10, 2)
  tax             Decimal        @db.Decimal(10, 2) @default(0)
  discount        Decimal        @db.Decimal(10, 2) @default(0)
  total           Decimal        @db.Decimal(10, 2)
  totalWeightKg   Decimal        @db.Decimal(8, 3)

  shippingMethod  ShippingMethod
  paymentProvider PaymentProvider
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentRef      String?        // Paystack/Stripe reference
  trackingNumber  String?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  shippedAt       DateTime?
  deliveredAt     DateTime?

  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  weightKg    Decimal @db.Decimal(6, 3)

  @@map("order_items")
}

// ─── SUBSCRIPTIONS (AUTO-SHIP) ──────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SubscriptionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  product         Product            @relation(fields: [productId], references: [id])
  quantity        Int                @default(1)
  interval        SubscriptionInterval @default(MONTHLY)
  status          SubscriptionStatus @default(ACTIVE)
  discountPercent Decimal            @db.Decimal(4, 2) @default(5.00)
  nextDelivery    DateTime
  paymentRef      String?            // recurring billing ref
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([nextDelivery])
  @@map("subscriptions")
}

// ─── RECIPES ────────────────────────────────────────────────

model Recipe {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  image       String?
  prepTime    Int          // minutes
  cookTime    Int          // minutes
  servings    Int
  instructions String     // markdown or HTML
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items       RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id          String  @id @default(cuid())
  recipeId    String
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int     @default(1)
  measurement String? // e.g., "2 cups", "1 tablespoon"

  @@map("recipe_items")
}

// ─── FLASH SALES ────────────────────────────────────────────

model FlashSale {
  id              String   @id @default(cuid())
  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPercent Decimal  @db.Decimal(4, 2)
  reason          String?  // e.g., "Near expiry"
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([isActive, endsAt])
  @@map("flash_sales")
}

// ─── SHIPPING RULES ────────────────────────────────────────

model ShippingRule {
  id            String        @id @default(cuid())
  name          String
  method        ShippingMethod
  minWeightKg   Decimal       @db.Decimal(8, 3)
  maxWeightKg   Decimal       @db.Decimal(8, 3)
  baseCost      Decimal       @db.Decimal(10, 2)
  perKgCost     Decimal       @db.Decimal(10, 2)
  estimatedDays Int
  isActive      Boolean       @default(true)

  @@map("shipping_rules")
}
